{
  "info": {
    "_postman_id": "mrc-fly-auth-collection-v1",
    "name": "🛡️ MRC Fly — Auth API",
    "description": "Complete authentication test suite for MRC Fly backend.\n\n**Setup:**\n1. Import this collection\n2. Import the `MRC_Fly_Auth.postman_environment.json` file alongside it\n3. Select the `MRC Fly Local` environment from the top-right dropdown\n4. Run requests in order (Register → Login → ...) or use Collection Runner for full suite\n\n**Auto-managed:**\n- `accessToken` is saved automatically after Login\n- `refreshToken` cookie is handled automatically by Postman\n- `userId`, `sessionToken`, `resetToken`, `verifyToken` are saved between requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1️⃣  Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has success message', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.message).to.include('Registration successful');",
              "});",
              "",
              "pm.test('No tokens exposed in register response (security check)', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.not.have.property('accessToken');",
              "    pm.expect(json).to.not.have.property('refreshToken');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Al Amin Islam\",\n  \"email\": \"alamin@mrcfly.com\",\n  \"password\": \"Test@1234\",\n  \"phone\": \"+8801700000000\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        },
        "description": "Register a new user. Returns only a message — no tokens are issued until email is verified."
      }
    },
    {
      "name": "2️⃣  Register — Duplicate Email (expect 409)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 409 Conflict', function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "",
              "pm.test('Error message mentions email already registered', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.message).to.include('already registered');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Al Amin Islam\",\n  \"email\": \"alamin@mrcfly.com\",\n  \"password\": \"Test@1234\",\n  \"phone\": \"+8801700000000\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        },
        "description": "Attempt to register with the same email — must return 409 Conflict."
      }
    },
    {
      "name": "3️⃣  Register — Weak Password (expect 400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Weak User\",\n  \"email\": \"weak@mrcfly.com\",\n  \"password\": \"1234\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        },
        "description": "Password too short — must return 400. Tests DTO @MinLength validation."
      }
    },
    {
      "name": "4️⃣  Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains accessToken', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('accessToken');",
              "    // Save for subsequent requests",
              "    pm.environment.set('accessToken', json.accessToken);",
              "});",
              "",
              "pm.test('Response contains user object', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.user).to.have.property('id');",
              "    pm.expect(json.user).to.have.property('email');",
              "    pm.expect(json.user).to.have.property('role');",
              "    pm.environment.set('userId', json.user.id);",
              "    pm.environment.set('sessionToken', json.sessionToken);",
              "});",
              "",
              "pm.test('refreshToken is NOT in response body (security check)', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.not.have.property('refreshToken');",
              "});",
              "",
              "pm.test('Set-Cookie header exists for refresh_token', function () {",
              "    pm.expect(pm.response.headers.get('Set-Cookie')).to.include('refresh_token');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alamin@mrcfly.com\",\n  \"password\": \"Test@1234\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        },
        "description": "Login with valid credentials. `accessToken` is saved to environment automatically.\n`refresh_token` is set as an HttpOnly cookie — Postman handles it automatically."
      }
    },
