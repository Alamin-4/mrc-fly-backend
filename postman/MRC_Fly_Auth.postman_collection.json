              "    pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Error message is generic (no user enumeration)', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.message).to.equal('Invalid credentials');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alamin@mrcfly.com\",\n  \"password\": \"WrongPassword!\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        },
        "description": "Wrong password — must return 401 with a generic message (no email enumeration)."
      }
    },
    {
      "name": "6️⃣  Login — Unknown Email (expect 401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 401 Unauthorized', function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Same error as wrong password (timing attack prevention)', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.message).to.equal('Invalid credentials');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"nobody@mrcfly.com\",\n  \"password\": \"Test@1234\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        },
        "description": "Unknown email — must return 401 with the SAME message as wrong password to prevent email enumeration."
      }
    },
    {
      "name": "7️⃣  Get Current User (/me)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Returns user object without sensitive data', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json).to.have.property('email');",
              "    pm.expect(json).to.have.property('role');",
              "    pm.expect(json).to.not.have.property('passwordHash');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        },
        "description": "Fetch authenticated user profile. Requires `Authorization: Bearer <accessToken>` header.\n`accessToken` is auto-populated from the Login step."
      }
    },
    {
      "name": "8️⃣  Get Current User — No Token (expect 401)",
      "event": [
