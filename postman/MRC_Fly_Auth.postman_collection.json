    {
      "name": "1️⃣8️⃣  Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response confirms logout', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.success).to.be.true;",
              "    pm.expect(json.message).to.include('Logged out');",
              "});",
              "",
              "pm.test('refresh_token cookie is cleared', function () {",
              "    const setCookie = pm.response.headers.get('Set-Cookie') || '';",
              "    // Cookie should be cleared (Max-Age=0 or expired)",
              "    pm.expect(setCookie).to.include('refresh_token');",
              "});",
              "",
              "// Clear stored tokens from environment",
              "pm.environment.unset('accessToken');",
              "pm.environment.unset('sessionToken');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
