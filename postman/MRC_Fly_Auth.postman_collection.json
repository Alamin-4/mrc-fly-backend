        "description": "Logout without a Bearer token — JwtAuthGuard must reject with 401."
      }
    },
    {
      "name": "2️⃣0️⃣  /me After Logout (expect 401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 401 after logout', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}", "description": "Old token — should be invalid after logout" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        },
        "description": "Attempt to use the old access token after logout. Note: since JWTs are stateless, this will still work until the 15-minute expiry unless you add a token blacklist (Redis). This test documents that behavior."
      }
    }
  ]
}
