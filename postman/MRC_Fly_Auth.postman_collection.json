            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        },
        "description": "Request without Bearer token — must return 401."
      }
    },
    {
      "name": "9️⃣  Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Returns new accessToken', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('accessToken');",
              "    // Update environment with new access token",
              "    pm.environment.set('accessToken', json.accessToken);",
              "});",
              "",
              "pm.test('refreshToken is NOT in response body', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.not.have.property('refreshToken');",
              "});",
              "",
              "pm.test('Set-Cookie rotates the refresh_token cookie', function () {",
              "    pm.expect(pm.response.headers.get('Set-Cookie')).to.include('refresh_token');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "refresh"]
        },
        "description": "Rotate the refresh token. The `refresh_token` HttpOnly cookie is sent automatically by Postman.\nReturns a new `accessToken` and rotates the cookie."
      }
    },
