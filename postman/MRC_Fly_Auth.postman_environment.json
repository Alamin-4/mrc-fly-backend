      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated after Login request"
    },
    {
      "key": "sessionToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Auto-populated after Login request"
    },
    {
      "key": "verifyEmailToken",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Manually paste the token from the verification email OR from DB: SELECT token FROM \"EmailVerification\" ORDER BY \"createdAt\" DESC LIMIT 1;"
    },
    {
      "key": "resetPasswordToken",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Manually paste the token from the reset email OR from DB: SELECT token FROM \"PasswordReset\" ORDER BY \"createdAt\" DESC LIMIT 1;"
    }
